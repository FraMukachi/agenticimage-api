{
  "name": "agenticimage-api",
  "version": 2,
  "builds": [
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.css", "use": "@vercel/static" },
    { "src": "**/*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/js/(.*)", "dest": "/js/$1", "headers": { "Content-Type": "application/javascript" } },
    { "src": "/css/(.*)", "dest": "/css/$1", "headers": { "Content-Type": "text/css" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Content-Type", "value": "application/javascript" }]
    }
  ]
}
